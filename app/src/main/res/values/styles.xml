<?xml version="1.0" encoding="utf-8"?>
<resources>

    <style name="AppTheme" parent="android:style/Theme.Material.NoActionBar">
        <item name="android:windowNoTitle">true</item>
        <item name="android:windowActionBar">false</item>
        <item name="android:fontFamily">monospace</item>
        <item name="android:colorAccent">#00FF66</item>
        <item name="android:navigationBarColor">#050505</item>
        <item name="android:windowLightNavigationBar">false</item>
    </style>

    <style name="HackerKey" parent="@android:style/Widget.Material.Button">
        <item name="android:background">@drawable/key_hacker</item>
        <item name="android:textColor">#00FF66</item>
        <item name="android:textSize">12sp</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:fontFamily">monospace</item>
        <item name="android:minHeight">0dp</item>
        <item name="android:minWidth">0dp</item>
        <item name="android:includeFontPadding">false</item>
        <item name="android:paddingLeft">2dp</item>
        <item name="android:paddingRight">2dp</item>
    </style>

</resources>
